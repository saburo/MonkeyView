{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Monkey View",
  "version": "0.1.0",
  "identifier": "com.kitajima.monkeyview",
  "mainBinaryName": "monkey_view",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png"],
    "macOS": {
      "bundleName": "Monkey View"
    }
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "capabilities": ["default"],
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$TEMP/monkey-view/*",
          "$TEMP/monkey-view/**/*"
        ]
      },
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost;",
      "devCsp": "default-src 'self' http://127.0.0.1:1420 ws://127.0.0.1:1420 ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data: blob: http://127.0.0.1:1420; style-src 'self' 'unsafe-inline' http://127.0.0.1:1420; script-src 'self' 'unsafe-inline' http://127.0.0.1:1420; connect-src 'self' ws://127.0.0.1:1420 http://127.0.0.1:1420 ipc: http://ipc.localhost;"
    },
    "windows": [
      {
        "label": "toolbar",
        "title": "Monkey View",
        "width": 836,
        "height": 104,
        "minWidth": 836,
        "maxWidth": 836,
        "minHeight": 104,
        "maxHeight": 420,
        "decorations": false,
        "transparent": true,
        "acceptFirstMouse": true,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": true,
        "skipTaskbar": true,
        "shadow": false,
        "center": true
      },
      {
        "label": "overlay",
        "title": "Monkey View Overlay",
        "width": 480,
        "height": 320,
        "decorations": false,
        "transparent": true,
        "acceptFirstMouse": true,
        "alwaysOnTop": true,
        "resizable": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false,
        "center": true
      }
    ]
  }
}
